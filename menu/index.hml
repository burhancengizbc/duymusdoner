<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    
    <title>Duymuş Döner | Dijital Menü</title>
    <meta name="description" content="Duymuş Döner Ergani dijital menüsü ve fiyat listesi. Nefis yaprak döner, hatay usulü ve içecekler.">
    
    <link rel="icon" type="image/jpeg" href="../logo.jpg?v=4">
    
    <!-- Google Fonts & FontAwesome -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    
    <style>
        :root {
            --bg-color: #0f0f11;
            --card-bg: #1a1a1e;
            --primary: #ffc107;
            --accent: #dc3545;
            --text-color: #ffffff;
            --text-muted: #a0a0a5;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Poppins', sans-serif;
        }

        body {
            background-color: var(--bg-color);
            color: var(--text-color);
            line-height: 1.6;
            padding-bottom: 80px; /* Sipariş butonu için boşluk */
        }

        /* Header (Geri Dönüş ve Logo) */
        header {
            position: sticky;
            top: 0;
            background-color: rgba(15, 15, 17, 0.95);
            backdrop-filter: blur(10px);
            z-index: 1000;
            border-bottom: 1px solid #2a2a30;
            padding: 15px 20px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .back-btn {
            color: var(--text-color);
            text-decoration: none;
            font-size: 16px;
            display: flex;
            align-items: center;
            gap: 8px;
            transition: color 0.3s;
        }

        .back-btn:hover {
            color: var(--primary);
        }

        .logo {
            font-size: 20px;
            font-weight: 700;
            color: var(--primary);
            text-decoration: none;
            letter-spacing: 1px;
        }

        .logo span {
            color: var(--accent);
        }

        /* Menü Başlığı */
        .menu-header {
            text-align: center;
            padding: 40px 20px 20px;
        }

        .menu-header h1 {
            font-size: 32px;
            color: var(--primary);
            margin-bottom: 10px;
        }

        .menu-header p {
            color: var(--text-muted);
            font-size: 15px;
        }

        /* Kategori Başlıkları */
        .category-title {
            max-width: 1000px;
            margin: 40px auto 20px;
            padding: 0 20px;
            font-size: 24px;
            color: var(--text-color);
            display: flex;
            align-items: center;
            gap: 10px;
        }
        
        .category-title i {
            color: var(--accent);
        }

        /* Menü Grid Yapısı */
        .menu-grid {
            max-width: 1000px;
            margin: 0 auto;
            padding: 0 20px;
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
            gap: 20px;
        }

        /* Menü Kartları */
        .menu-card {
            background-color: var(--card-bg);
            border: 1px solid #2a2a30;
            border-radius: 12px;
            overflow: hidden;
            display: flex;
            flex-direction: column;
            transition: transform 0.3s, border-color 0.3s;
        }

        .menu-card:hover {
            transform: translateY(-5px);
            border-color: var(--primary);
        }

        .menu-img-wrapper {
            width: 100%;
            height: 180px;
            overflow: hidden;
            position: relative;
        }

        .menu-card img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            transition: transform 0.3s;
        }

        .menu-card:hover img {
            transform: scale(1.05);
        }

        .menu-info {
            padding: 15px;
            display: flex;
            flex-direction: column;
            flex-grow: 1;
            justify-content: space-between;
        }

        .menu-title-row {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            gap: 10px;
            margin-bottom: 8px;
        }

        .menu-name {
            font-size: 16px;
            font-weight: 600;
            color: var(--text-color);
            line-height: 1.3;
        }

        .menu-price {
            font-size: 18px;
            font-weight: 700;
            color: var(--primary);
            white-space: nowrap;
        }

        .menu-desc {
            font-size: 13px;
            color: var(--text-muted);
        }

        /* Sabit Sipariş Butonu */
        .floating-order {
            position: fixed;
            bottom: 20px;
            left: 50%;
            transform: translateX(-50%);
            background-color: #25d366;
            color: white;
            padding: 12px 30px;
            border-radius: 50px;
            text-decoration: none;
            font-weight: 600;
            display: flex;
            align-items: center;
            gap: 10px;
            box-shadow: 0 4px 15px rgba(37, 211, 102, 0.4);
            z-index: 1000;
            transition: transform 0.3s;
        }

        .floating-order:hover {
            transform: translateX(-50%) scale(1.05);
        }

        @media (max-width: 600px) {
            .menu-grid {
                grid-template-columns: 1fr; /* Mobilde tek sütun alt alta */
            }
            .menu-img-wrapper {
                height: 200px;
            }
        }
    </style>
</head>
<body>

    <!-- Üst Bar -->
    <header>
        <a href="../index.html" class="back-btn"><i class="fa-solid fa-arrow-left"></i> Ana Sayfa</a>
        <a href="../index.html" class="logo">Duymuş<span>Döner</span></a>
    </header>

    <!-- Başlık -->
    <div class="menu-header">
        <h1>Dijital Menü</h1>
        <p>Eşsiz lezzetlerimiz sizin için hazırlandı.</p>
    </div>

    <!-- 1. Kategori: Döner Çeşitleri -->
    <div class="category-title"><i class="fa-solid fa-fire-burner"></i> Ana Lezzetler</div>
    <div class="menu-grid">
        
        <!-- Ürün 1 -->
        <div class="menu-card">
            <div class="menu-img-wrapper">
                <img src="ekmek-arasi.jpg" alt="Ekmek Arası Klasik Döner" onerror="this.src='https://images.unsplash.com/photo-1633964913295-ceb43826e7c9?auto=format&fit=crop&w=500&q=80'">
            </div>
            <div class="menu-info">
                <div class="menu-title-row">
                    <div class="menu-name">Ekmek Arası Klasik (Eski Usul) Döner</div>
                    <div class="menu-price">100 ₺</div>
                </div>
                <div class="menu-desc">Geleneksel lezzet, çıtır ekmek arasında.</div>
            </div>
        </div>

        <!-- Ürün 2 -->
        <div class="menu-card">
            <div class="menu-img-wrapper">
                <img src="lavas.jpg" alt="Lavaş Klasik Döner" onerror="this.src='https://images.unsplash.com/photo-1529193591184-b1d58069ecdd?auto=format&fit=crop&w=500&q=80'">
            </div>
            <div class="menu-info">
                <div class="menu-title-row">
                    <div class="menu-name">Lavaş Klasik (Eski Usul) Döner</div>
                    <div class="menu-price">100 ₺</div>
                </div>
                <div class="menu-desc">Sıcak ve yumuşacık lavaş ile sarılı lezzet şöleni.</div>
            </div>
        </div>

        <!-- Ürün 3 -->
        <div class="menu-card">
            <div class="menu-img-wrapper">
                <img src="hatay-soslu.jpg" alt="Hatay Özel Soslu Döner" onerror="this.src='https://images.unsplash.com/photo-1561651823-34fed022540e?auto=format&fit=crop&w=500&q=80'">
            </div>
            <div class="menu-info">
                <div class="menu-title-row">
                    <div class="menu-name">Hatay Özel Soslu Döner</div>
                    <div class="menu-price">100 ₺</div>
                </div>
                <div class="menu-desc">Özel baharatlar ve imza sosumuzla harmanlanmış dürüm.</div>
            </div>
        </div>

        <!-- Ürün 4 -->
        <div class="menu-card">
            <div class="menu-img-wrapper">
                <img src="porsiyon.jpg" alt="Porsiyon Döner" onerror="this.src='https://images.unsplash.com/photo-1544025162-d76694265947?auto=format&fit=crop&w=500&q=80'">
            </div>
            <div class="menu-info">
                <div class="menu-title-row">
                    <div class="menu-name">Porsiyon Döner</div>
                    <div class="menu-price">200 ₺</div>
                </div>
                <div class="menu-desc">Tabakta şık sunum, yanında garnitürleri ile tam doyurucu.</div>
            </div>
        </div>

    </div>

    <!-- 2. Kategori: İçecekler -->
    <div class="category-title" style="margin-top: 60px;"><i class="fa-solid fa-glass-water"></i> İçecekler</div>
    <div class="menu-grid">
        
        <!-- Ürün 5 -->
        <div class="menu-card">
            <div class="menu-img-wrapper">
                <img src="su.jpg" alt="Su" onerror="this.src='https://images.unsplash.com/photo-1548839140-29a749e1bc4e?auto=format&fit=crop&w=500&q=80'">
            </div>
            <div class="menu-info">
                <div class="menu-title-row">
                    <div class="menu-name">Su</div>
                    <div class="menu-price">10 ₺</div>
                </div>
            </div>
        </div>

        <!-- Ürün 6 -->
        <div class="menu-card">
            <div class="menu-img-wrapper">
                <img src="ayran.jpg" alt="Ayran (Büyük)" onerror="this.src='https://images.unsplash.com/photo-1628557044797-f21a177c37ec?auto=format&fit=crop&w=500&q=80'">
            </div>
            <div class="menu-info">
                <div class="menu-title-row">
                    <div class="menu-name">Ayran (Büyük)</div>
                    <div class="menu-price">20 ₺</div>
                </div>
            </div>
        </div>

        <!-- Ürün 7 -->
        <div class="menu-card">
            <div class="menu-img-wrapper">
                <img src="kola-kutu.jpg" alt="Kola Kutu" onerror="this.src='https://images.unsplash.com/photo-1622483767028-3f66f32aef97?auto=format&fit=crop&w=500&q=80'">
            </div>
            <div class="menu-info">
                <div class="menu-title-row">
                    <div class="menu-name">Kola Kutu</div>
                    <div class="menu-price">60 ₺</div>
                </div>
            </div>
        </div>

        <!-- Ürün 8 -->
        <div class="menu-card">
            <div class="menu-img-wrapper">
                <img src="fanta-kutu.jpg" alt="Fanta Kutu" onerror="this.src='https://images.unsplash.com/photo-1622483767028-3f66f32aef97?auto=format&fit=crop&w=500&q=80'">
            </div>
            <div class="menu-info">
                <div class="menu-title-row">
                    <div class="menu-name">Fanta Kutu</div>
                    <div class="menu-price">60 ₺</div>
                </div>
            </div>
        </div>

        <!-- Ürün 9 -->
        <div class="menu-card">
            <div class="menu-img-wrapper">
                <img src="kola-1lt.jpg" alt="Kola 1 lt" onerror="this.src='https://images.unsplash.com/photo-1622483767028-3f66f32aef97?auto=format&fit=crop&w=500&q=80'">
            </div>
            <div class="menu-info">
                <div class="menu-title-row">
                    <div class="menu-name">Kola 1 lt.</div>
                    <div class="menu-price">80 ₺</div>
                </div>
            </div>
        </div>

        <!-- Ürün 10 -->
        <div class="menu-card">
            <div class="menu-img-wrapper">
                <img src="fanta-1lt.jpg" alt="Fanta 1 lt" onerror="this.src='https://images.unsplash.com/photo-1622483767028-3f66f32aef97?auto=format&fit=crop&w=500&q=80'">
            </div>
            <div class="menu-info">
                <div class="menu-title-row">
                    <div class="menu-name">Fanta 1 lt.</div>
                    <div class="menu-price">80 ₺</div>
                </div>
            </div>
        </div>

        <!-- Ürün 11 -->
        <div class="menu-card">
            <div class="menu-img-wrapper">
                <img src="kola-25lt.jpg" alt="Kola 2.5 lt" onerror="this.src='https://images.unsplash.com/photo-1622483767028-3f66f32aef97?auto=format&fit=crop&w=500&q=80'">
            </div>
            <div class="menu-info">
                <div class="menu-title-row">
                    <div class="menu-name">Kola 2.5 lt.</div>
                    <div class="menu-price">100 ₺</div>
                </div>
            </div>
        </div>

        <!-- Ürün 12 -->
        <div class="menu-card">
            <div class="menu-img-wrapper">
                <img src="fanta-25lt.jpg" alt="Fanta 2.5 lt" onerror="this.src='https://images.unsplash.com/photo-1622483767028-3f66f32aef97?auto=format&fit=crop&w=500&q=80'">
            </div>
            <div class="menu-info">
                <div class="menu-title-row">
                    <div class="menu-name">Fanta 2.5 lt.</div>
                    <div class="menu-price">100 ₺</div>
                </div>
            </div>
        </div>

    </div>

    <!-- Sabit Sipariş Butonu -->
    <a href="https://wa.me/905373459260" target="_blank" class="floating-order">
        <i class="fa-brands fa-whatsapp" style="font-size: 20px;"></i> Hemen Sipariş Ver
    </a>

</body>
</html>
            
